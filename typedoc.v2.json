{
  "$schema": "https://typedoc.org/schema.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "./docs/v2/types/",
  "readme": "none",
  "entryPoints": [
    "./v2/index.ts",
    "./v2/svg/index.ts",
    "./v2/testing/index.ts"
  ],
  "entryFileName": "index",
  "excludePrivate": true,
  "excludeInternal": true,
  "validation": {
    "notExported": true,
    "invalidLink": true,
    "notDocumented": true
  }
}
